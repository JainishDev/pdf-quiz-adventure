---
import QuizApp from "../components/QuizApp.jsx";
import "../styles/pokemon.css";

const siteUrl = "https://your-domain-here.com"; // TODO: replace with your real deployed domain
const ogImage = `${siteUrl}/og-image.png`; // TODO: add a 1200x630 og-image.png to /client/public if you want rich link previews
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- ── Primary SEO ─────────────────────────────────────────────────── -->
    <title>PDF Quiz Adventure — Turn any PDF into an AI Quiz Game</title>
    <meta
      name="description"
      content="Upload any PDF and instantly get an AI-generated, Pokemon-style quiz. Timed questions, XP, combos, power-ups, streaks and a leaderboard — studying, gamified."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />
    <meta name="theme-color" content="#1a2b3c" />
    <meta name="color-scheme" content="light dark" />

    <!-- ── Open Graph / Social ─────────────────────────────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="PDF Quiz Adventure — Turn any PDF into an AI Quiz Game" />
    <meta
      property="og:description"
      content="Upload any PDF and instantly get an AI-generated, Pokemon-style quiz with XP, combos, power-ups and a leaderboard."
    />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="PDF Quiz Adventure" />
    <meta name="twitter:description" content="Upload any PDF, get an AI-generated quiz — Pokemon FireRed style." />
    <meta name="twitter:image" content={ogImage} />

    <!-- ── Favicon ───────────────────────────────────────────────────────── -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#1a2b3c" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- ── Perf: connect early to the font host, load non-blocking ─────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" />
    </noscript>

    <!-- ── Structured data (technical SEO) ──────────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "PDF Quiz Adventure",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "Any",
      "description": "Upload any PDF and instantly get an AI-generated, Pokemon-style quiz with timers, XP, combos, power-ups and a leaderboard.",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />

    <!-- ── Anti-flash: apply the saved theme before first paint ─────────── -->
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem("pdfQuizAdventure.theme.v1");
          var t = raw ? JSON.parse(raw) : "day";
          document.documentElement.dataset.theme = t === "night" ? "night" : "day";
        } catch (e) {
          document.documentElement.dataset.theme = "day";
        }
      })();
    </script>
  </head>
  <body>
    <div class="sky-layer" aria-hidden="true"></div>
    <QuizApp client:load />
  </body>
</html>